{
	"hooks": {
		"SessionStart": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "pwsh -NoProfile -Command \"if (-not $env:OVERSTORY_AGENT_NAME) { exit 0 }; overstory prime --agent {{AGENT_NAME}}\""
					}
				]
			}
		],
		"UserPromptSubmit": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "pwsh -NoProfile -Command \"if (-not $env:OVERSTORY_AGENT_NAME) { exit 0 }; overstory mail check --inject --agent {{AGENT_NAME}}\""
					}
				]
			}
		],
		"PreToolUse": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "pwsh -NoProfile -Command \"if (-not $env:OVERSTORY_AGENT_NAME) { exit 0 }; $INPUT = [Console]::In.ReadLine(); $INPUT | overstory log tool-start --agent {{AGENT_NAME}} --stdin\""
					}
				]
			}
		],
		"PostToolUse": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "pwsh -NoProfile -Command \"if (-not $env:OVERSTORY_AGENT_NAME) { exit 0 }; $INPUT = [Console]::In.ReadLine(); $INPUT | overstory log tool-end --agent {{AGENT_NAME}} --stdin\""
					},
					{
						"type": "command",
						"command": "pwsh -NoProfile -Command \"if (-not $env:OVERSTORY_AGENT_NAME) { exit 0 }; overstory mail check --inject --agent {{AGENT_NAME}} --debounce 500\""
					}
				]
			},
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "pwsh -NoProfile -Command \"if (-not $env:OVERSTORY_AGENT_NAME) { exit 0 }; overstory mail check --inject --agent {{AGENT_NAME}} --debounce 30000\""
					}
				]
			}
		],
		"Stop": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "pwsh -NoProfile -Command \"if (-not $env:OVERSTORY_AGENT_NAME) { exit 0 }; $INPUT = [Console]::In.ReadLine(); $INPUT | overstory log session-end --agent {{AGENT_NAME}} --stdin\""
					},
					{
						"type": "command",
						"command": "pwsh -NoProfile -Command \"if (-not $env:OVERSTORY_AGENT_NAME) { exit 0 }; mulch learn\""
					}
				]
			}
		],
		"PreCompact": [
			{
				"matcher": "",
				"hooks": [
					{
						"type": "command",
						"command": "pwsh -NoProfile -Command \"if (-not $env:OVERSTORY_AGENT_NAME) { exit 0 }; overstory prime --agent {{AGENT_NAME}} --compact\""
					}
				]
			}
		]
	}
}
